#!/bin/sh /etc/rc.common
# router-diag — AI-Powered Router Diagnostics

START=99
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    # 'daemon' subcommand runs daemon_loop in the foreground so procd can supervise it.
    # Using 'start' here would background the loop and procd would respawn-spam.
    procd_set_param command /usr/bin/router-diag daemon
    procd_set_param respawn 3600 30 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    /usr/bin/router-diag stop
}

service_triggers() {
    procd_add_reload_trigger "router-diag"
}
